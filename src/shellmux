#!/usr/bin/env bash
# shellmux — a content-blind topic pub/sub broker in ~150 lines of shell.
#
# Built from socat-fork + FIFOs + flock. Two of the three things people pay
# clustered brokers for — per-subscriber isolation and forget-on-death — fall
# out of fork-per-connection for free. The one hard contribution is the
# data-derived deadline scheduler (src/sched.sh, proven by tests/chaos_deadline.sh).
#
# Borrowed relay shape (from a socat-fork terminal relay; mechanisms reused, not
# invented here):
#   socat-fork acceptor       (we use EXEC: + ,fork)
#   per-client FIFO + drainer
#   [ -p ]-guarded fan-out
#   pkill -P cleanup
# We REPLACE that relay's `printf ... > $f &` blocking-write-backgrounded leak
# (a stuck process per message to a wedged peer) — see the bounded ring drainer.
#
# Usage:
#   shellmux serve <dir> [--unix <path>] [--tcp <port>]   start the broker
#   shellmux sub   <dir> <topic> [--unix <path>|--tcp <port>]   subscribe (prints msgs)
#   shellmux pub   <dir> <topic> [--unix ...|--tcp ...]         publish (stdin = payload lines)
#   shellmux _handle <dir>                                internal: socat-forked handler
#
# All state is the filesystem under <dir>: topics/<t>/sub_<pid>.fifo, deferred/,
# outbox/, wake.fifo. Introspect with ls/cat. No auth, no admin protocol.
set -uo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
SCHED="$(dirname "$SELF")/sched.sh"
SHELLMUX_VERSION="0.1.1"

die() { printf 'shellmux: %s\n' "$*" >&2; exit 1; }

# main_usage [rc] — top-level help. rc 0 (explicit help) prints to stdout; a
# nonzero rc (unknown/empty command) prints to stderr, so `$?` distinguishes a
# happy `--help` from a usage error (same arg-rc discipline as sub/pub usage()).
main_usage() {
  local rc="${1:-0}" out=1
  [ "$rc" -ne 0 ] && out=2
  {
    printf 'shellmux %s — a content-blind topic pub/sub broker in shell\n\n' "$SHELLMUX_VERSION"
    printf 'usage:\n'
    printf '  shellmux serve <dir> [--unix <path>] [--tcp <port>]   start the broker\n'
    printf '  shellmux sub   <dir> <topic> [--unix <path>|--tcp <port>]\n'
    printf '  shellmux pub   <dir> <topic> [--at <epoch>|--delay <s>] [--unix <path>|--tcp <port>]\n'
    printf '  shellmux --version | --help\n\n'
    printf 'state lives under <dir> (topics/, deferred/, outbox/); introspect with ls/cat.\n'
    printf 'docs: https://github.com/bobbyrathoree/shellmux  (README, DEMO.md)\n'
  } >&"$out"
  exit "$rc"
}

# now_ms -> sets $REPLY to current unix time in ms (same fork-free convention as
# src/sched.sh: $EPOCHREALTIME builtin on bash>=5, `date` fallback on bash 4).
if [ -n "${EPOCHREALTIME:-}" ]; then
  now_ms() { local e=$EPOCHREALTIME; REPLY=$(( ${e%.*} * 1000 + 10#${e#*.} / 1000 )); }
else
  now_ms() { REPLY=$(date +%s%3N); }
fi

# --- input validation at the data boundary (round-1 evaluator findings) -------
# The M0 chaos proof covers WELL-FORMED deadlines; it never exercised hostile
# control input. Two adversarial product personas independently found the input
# boundary fails silently: a non-numeric/float/out-of-range --at/--delay crashes
# the per-connection handler (`$2: unbound` / arithmetic error) yet the publisher
# sees rc=0 (F1/F7), and an unsanitized topic name is a path component, so the
# broker mkdir's OUTSIDE the state dir (`../../../tmp/x`) — a publisher-controlled
# mkdir-anywhere primitive (H1). These gates reject hostile input BEFORE it
# reaches the scheduler or the filesystem. They touch only the input boundary —
# never src/sched.sh, the mv commit point, or the wake discipline — so the proof
# is insulated by construction (V3 in tests/input_validation.sh confirms the
# legitimate deferred path is unchanged; chaos_deadline.sh confirms 0/0 holds).
# All gates are behind SHELLMUX_NO_VALIDATE=1 (the must-fail negative control):
# disabling them brings the crash + traversal back, proving the gates are load-
# bearing — same one-knob-auditable discipline as SHELLMUX_NO_TRAP / LEAKY_WRITE.

# valid_topic <name> -> 0 if a safe single path segment, 1 otherwise. A topic is
# a directory name under topics/; it must not be able to climb out (`..`, `/`),
# hide (leading `.`), or carry whitespace/metacharacters that word-split or
# survive into a shell. Whitelist [A-Za-z0-9._-]+, reject a leading dot.
valid_topic() {
  [ "${SHELLMUX_NO_VALIDATE:-0}" = "1" ] && return 0
  case "$1" in
    ''|.*|*[!A-Za-z0-9._-]*) return 1 ;;
    *) return 0 ;;
  esac
}

# valid_deadline <kind> <value> -> 0 if usable, 1 otherwise. <kind> is "at"
# (absolute unix seconds) or "delay" (relative seconds). Both must be a plain
# non-negative integer (no float, no sign, no garbage — the arithmetic the
# scheduler derives its MIN from is integer ms). An absolute --at must not be so
# far in the future that it parks an effectively-never-firing record in deferred/
# (F7): cap the horizon at SHELLMUX_MAX_DEFER_S seconds past now (default ~1yr).
valid_deadline() {
  [ "${SHELLMUX_NO_VALIDATE:-0}" = "1" ] && return 0
  local kind="$1" v="$2"
  case "$v" in ''|*[!0-9]*) return 1 ;; esac     # non-negative integer only
  local horizon="${SHELLMUX_MAX_DEFER_S:-31536000}"
  if [ "$kind" = "at" ]; then
    now_ms; local now_s=$(( REPLY / 1000 ))
    [ "$v" -le $(( now_s + horizon )) ] || return 1
  else
    [ "$v" -le "$horizon" ] || return 1
  fi
  return 0
}

# ---------------------------------------------------------------------------
# fanout <record> <topic_dir>  — deliver one record to every live subscriber.
#   The publisher writes each subscriber's FIFO (NEVER the socket). Boundedness
#   comes from the kernel pipe buffer (~64KiB on Linux) used AS a ring: a healthy
#   subscriber's FIFO is drained, so the write is ~microseconds; a wedged
#   subscriber's FIFO fills to the buffer limit, the timeout-bounded write is
#   killed depositing zero bytes, and we drop + bump a visible drops_<pid>.
#   Crucially there is NO `&` — exactly ONE serial, timeout-bounded write per
#   subscriber per record — so the publisher never accumulates processes. This
#   replaces the borrowed relay's `printf ... > $f &` leak, which spawns one
#   stuck process per message to a wedged peer.
#   Records are length-prefixed on the wire to the FIFO (`<decimal-len>\n<bytes>`)
#   so a torn write is caught by the drainer's short-read and discarded.
#   Honest: this is NOT fork-free (each write is a ~675us `timeout bash -c`); the
#   claim is "no per-message process ACCUMULATION", which is what keeps ps flat.
fanout() {
  local rec="$1" td="$2" f pid frame
  # Write timeout: a healthy (drained) sub's write completes in microseconds, so
  # even a small timeout has a huge safety margin (measured: 500/500 healthy
  # writes succeed at a 5ms timeout). A wedged sub's write is abandoned after
  # ~this long, so a wedged peer slows the publisher by at most WRITE_TIMEOUT per
  # dropped record — bounded and small — instead of stalling it. Tunable; the
  # default trades a little wedged-abandon latency for robustness on slow hardware.
  local wto="${SHELLMUX_WRITE_TIMEOUT:-0.05}"
  frame="${#rec}"$'\n'"$rec"
  for f in "$td"/sub_*.fifo; do
    [ -e "$f" ] || continue                  # glob-no-match guard
    [ "$f" = "${INFIFO:-}" ] && continue      # skip self (no-op in PUB handler)
    [ -p "$f" ] || continue                   # skip non-pipes (dead/forgotten subs)
    if [ "${SHELLMUX_LEAKY_WRITE:-0}" = "1" ]; then
      # NEGATIVE CONTROL ONLY (tests/flood_wedged.sh F3'): the bug we replace.
      # A blocking write backgrounded with & -> one stuck process PER message to
      # a wedged sub. The test asserts this BALLOONS. Never used in production.
      printf '%s' "$frame" > "$f" 2>/dev/null &
    else
      # PRODUCTION: one serial, timeout-bounded write. The open AND write live
      # inside the timeout-governed bash -c, so even a blocking open (sub died in
      # a race, FIFO present but no reader) is bounded — not just the write.
      pid="${f##*/sub_}"; pid="${pid%.fifo}"
      # Per-subscriber WRITE LOCK: a FIFO write is atomic only up to PIPE_BUF
      # (~4096B on Linux), so two concurrent socat-forked publishers fanning out
      # records LARGER than PIPE_BUF to the SAME sub would interleave their bytes,
      # and a torn/concatenated frame whose size happens to match the length
      # prefix slips past the drainer's short-read guard and reaches the sub
      # corrupted (tests/concurrent_frames.sh). flock on a PER-SUB lock makes the
      # whole frame write atomic w.r.t. other publishers to that sub. The lock is
      # per-subscriber (.wlock_<pid>), NOT global, so writes to DIFFERENT subs
      # still run in parallel and a wedged peer never blocks a healthy one (the M3
      # isolation property holds). fd 8 is opened INSIDE the timeout-governed
      # bash -c, so the lock is released when the write completes OR is killed by
      # the timeout — a wedged sub still drops + bumps drops_<pid> exactly as
      # before; only atomicity is added, not a change to the backpressure contract.
      # SHELLMUX_NO_WLOCK=1 drops the lock (the one-knob must-fail control, G1'):
      # the interleave corruption returns, proving the lock is load-bearing.
      local writer
      if [ "${SHELLMUX_NO_WLOCK:-0}" = "1" ]; then
        writer='printf "%s" "$2" > "$1"'                       # pre-fix: unlocked
      else
        writer='exec 8>"$3"; flock 8; printf "%s" "$2" > "$1"' # locked per-sub
      fi
      if ! timeout "$wto" bash -c "$writer" _ "$f" "$frame" "$td/.wlock_$pid" 2>/dev/null; then
        # serialize the read-modify-write so concurrent publishers to the same
        # wedged sub don't lose increments (flock'd-counter shape,
        # the borrowed flock'd-counter shape). `local` is invalid in a ( ) subshell, so v
        # is a plain assignment scoped to the subshell.
        ( flock 9
          v=$(cat "$td/drops_$pid" 2>/dev/null)
          printf '%d\n' $(( ${v:-0} + 1 )) > "$td/drops_$pid"
        ) 9>"$td/.drops.lock"
      fi
    fi
  done
}

# ---------------------------------------------------------------------------
# _handle <dir>  — runs once per connection (socket on stdin/stdout via socat).
#   Reads ONE control line. SUB <topic>: register a mailbox FIFO, drain it to
#   the socket, hold it open, block until the client disconnects (stdin EOF),
#   then the EXIT trap unlinks the FIFO (forget-on-death). PUB <topic> [opts]:
#   stream records into the topic's fan-out (M3) / deferred scheduler.
# ---------------------------------------------------------------------------
_handle() {
  local dir="$1"
  local ctl; IFS= read -r ctl || exit 0
  local verb="${ctl%% *}" rest="${ctl#* }"
  case "$verb" in
    SUB)
      local topic="$rest" td
      [ -n "$topic" ] && [ "$topic" != "SUB" ] || exit 0
      # Reject a hostile topic name server-side (a raw socat client bypasses the
      # `sub` helper, so this is the load-bearing check, not the client one).
      valid_topic "$topic" || { printf 'shellmux: bad topic name\n' >&2; exit 1; }
      td="$dir/topics/$topic"; mkdir -p "$td"
      # INFIFO is intentionally NOT `local`: the EXIT trap runs in the top-level
      # script scope where a function-local would be out of scope (and under
      # `set -u` that aborts the trap before the rm — forget-on-death would
      # silently never fire). A handler process serves exactly one connection,
      # so a script-global is correct here.
      INFIFO="$td/sub_$$.fifo"
      mkfifo "$INFIFO" 2>/dev/null || exit 1
      # forget-on-death: unlink the mailbox when this handler dies (disconnect,
      # signal, crash). The shell analog of the reference queue's opportunistic
      # "disconnected => drop" leaf prune. SHELLMUX_NO_TRAP=1 skips it (test control).
      [ "${SHELLMUX_NO_TRAP:-0}" = "1" ] || trap 'rm -f "$INFIFO"' EXIT
      local pid="$$" wto="${SHELLMUX_WRITE_TIMEOUT:-0.05}"
      # drainer: the ONLY writer to the socket (stdout) and the OWNER of
      # backpressure. It reads length-prefixed frames from its FIFO and does a
      # BOUNDED write of each payload to the socket; if that write times out (the
      # client is wedged — not reading its socket) the frame is DROPPED and
      # drops_<pid> is bumped. Because the drainer keeps reading the FIFO at full
      # speed and drops on a slow socket, the FIFO stays drained, so a wedged
      # subscriber NEVER backs up to the publisher — healthy subscribers are fully
      # decoupled from a wedged peer. This is the corrected backpressure unit:
      # exactly ONE long-lived drainer per subscriber, no per-message process.
      #
      # Torn-frame defense (three layers): (1) a non-numeric/empty length line is
      # junk -> skip, resyncing on the next prefix; (2) strict length match
      # discards a short (torn) read instead of concatenating it; (3) the bounded
      # payload read (-t 0.5) prevents a stall mid-payload from wedging the drainer.
      # A payload-read timeout is a torn-frame discard, NOT a drop (drops are a
      # socket-write-timeout property), so an idle healthy sub never false-drops.
      ( exec 9>"$td/.drops.lock"
        while IFS= read -r len; do
          case "$len" in *[!0-9]*|'') continue ;; esac
          IFS= read -r -N "$len" -t 0.5 payload || continue
          [ "${#payload}" -eq "$len" ] || continue
          if ! timeout "$wto" bash -c 'printf "%s\n" "$1"' _ "$payload" 2>/dev/null; then
            flock 9
            v=$(cat "$td/drops_$pid" 2>/dev/null)
            printf '%d\n' $(( ${v:-0} + 1 )) > "$td/drops_$pid"
            flock -u 9
          fi
        done < "$INFIFO" ) &
      # keepalive: hold the FIFO open for writing so the drainer never sees EOF
      # as publishers come and go (the borrowed relay's keepalive fd).
      exec 3>"$INFIFO"
      # block until the client disconnects (socket EOF on stdin); then fall off
      # the end and the EXIT trap fires.
      while IFS= read -r _; do :; done
      ;;
    PUB)
      # "PUB <topic> [--at <epoch>|--delay <s>]" then stream records (one per
      # line) on stdin. The broker parses ONLY this control line, never payloads.
      local topic="" at="" delay="" tok
      set -- $rest
      topic="${1:-}"; shift || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --at)    at="$2"; shift 2 ;;
          --delay) delay="$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      [ -n "$topic" ] || exit 0
      # Reject a hostile topic name server-side (mkdir-anywhere primitive, H1).
      valid_topic "$topic" || { printf 'shellmux: bad topic name\n' >&2; exit 1; }
      # Reject a malformed/out-of-range deadline BEFORE the arithmetic that would
      # otherwise crash this handler under `set -u` (F1: `--at xyz` -> unbound;
      # `--delay 1.5` -> arith error) or park a never-firing record (F7).
      [ -z "$delay" ] || valid_deadline delay "$delay" || { printf 'shellmux: bad --delay\n' >&2; exit 1; }
      [ -z "$at" ]    || valid_deadline at    "$at"    || { printf 'shellmux: bad --at\n'    >&2; exit 1; }
      local td="$dir/topics/$topic"; mkdir -p "$td"
      # Compute the run-at deadline in ms epoch. --delay wins over --at (matches
      # the reference queue's enqueue precedence). No deadline => immediate.
      local run_at_ms=""
      if [ -n "$delay" ]; then now_ms; run_at_ms=$(( REPLY + delay * 1000 ))
      elif [ -n "$at" ]; then run_at_ms=$(( at * 1000 )); fi

      while IFS= read -r rec; do
        if [ -n "$run_at_ms" ]; then
          # DEFERRED publish: stage the record FIRST, THEN poke the wake-FIFO
          # (stage-then-poke; the reverse loses the wake — the borrowed ordering rule).
          # The file encodes its topic so the scheduler's fire hook can fan it out.
          # A global deferred/ keeps one scheduler scanning a single MIN over all
          # topics (the M0 discipline, unchanged).
          local seq="${RANDOM}${RANDOM}"
          printf '%s\n%s' "$topic" "$rec" > "$dir/deferred/${run_at_ms}.${seq}"
          printf 'x' > "$dir/wake.fifo" 2>/dev/null || true
        else
          fanout "$rec" "$td"          # immediate publish
        fi
      done
      exit 0
      ;;
    *)
      exit 0 ;;
  esac
}

# ---------------------------------------------------------------------------
# _fire <outbox_file>  — the scheduler's delivery hook (SCHED_FIRE_HOOK). The
#   deferred file's content is "<topic>\n<payload>"; fan the payload into that
#   topic. <dir> is taken from SHELLMUX_DIR (exported by serve).
# ---------------------------------------------------------------------------
_fire() {
  local file="$1" dir="${SHELLMUX_DIR:?}"
  [ -e "$file" ] || return 0
  local topic rec
  IFS= read -r topic < "$file"            # first line = topic
  rec="$(sed '1d' "$file")"               # remainder = payload (may be multi-line)
  [ -n "$topic" ] || return 0
  fanout "$rec" "$dir/topics/$topic"
}

# ---------------------------------------------------------------------------
# _reap <dir>  — one GC sweep over broker state. Removes:
#   - a drops_<pid> or .wlock_<pid> whose sub_<pid>.fifo no longer exists (the
#     subscriber died; its forget-on-death EXIT trap unlinks the FIFO but not the
#     per-sub counter/lock files);
#   - orphaned deferred/ files older than SHELLMUX_DEFERRED_TTL seconds (default
#     86400) — a safety net for records whose delivery was abandoned;
#   - empty topic directories.
# It NEVER touches a live subscriber's FIFO, a live drops file, or a non-empty
# topic. Idempotent; safe to run on any timer. (serve runs it on a slow loop.)
_reap() {
  local dir="$1" td t b pid f ttl now
  ttl="${SHELLMUX_DEFERRED_TTL:-86400}"
  for td in "$dir"/topics/*/; do
    [ -d "$td" ] || continue
    # stale per-sub state: a drops_<pid> counter or .wlock_<pid> fan-out lock
    # whose sub_<pid>.fifo no longer exists (the subscriber died).
    for f in "$td"drops_* "$td".wlock_*; do
      [ -e "$f" ] || continue
      b=${f##*/}; pid=${b#drops_}; pid=${pid#.wlock_}
      [ -p "${td}sub_${pid}.fifo" ] || rm -f "$f"
    done
    # empty topic dir (no entries at all)
    rmdir "$td" 2>/dev/null || true
  done
  # orphaned deferred files older than the TTL (find -mmin in minutes)
  if [ -d "$dir/deferred" ]; then
    find "$dir/deferred" -type f -mmin "+$(( ttl / 60 ))" -delete 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# serve <dir> [--unix <path>] [--tcp <port>]
#   Start the scheduler + a socat fork-EXEC acceptor per requested transport.
#   Each connection forks a fresh `_handle` with the socket on stdin/stdout.
# ---------------------------------------------------------------------------
serve() {
  local dir="$1"; shift
  local unix_path="" tcp_port=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --unix) unix_path="$2"; shift 2 ;;
      --tcp)  tcp_port="$2";  shift 2 ;;
      *) die "serve: unknown arg $1" ;;
    esac
  done
  [ -n "$unix_path" ] || [ -n "$tcp_port" ] || die "serve: need --unix and/or --tcp"

  mkdir -p "$dir/topics" "$dir/deferred" "$dir/outbox"
  [ -p "$dir/wake.fifo" ] || mkfifo "$dir/wake.fifo"

  # Export config BEFORE launching children so both the socat-forked handlers
  # (drainer) AND the scheduler's _fire delivery hook (fanout) see it.
  # socat EXEC: execvp's the first token directly (NO shell), so an env-var
  # prefix would be taken as the program name — hence export, not a cmd prefix.
  export SHELLMUX_NO_TRAP="${SHELLMUX_NO_TRAP:-0}"
  export SHELLMUX_LEAKY_WRITE="${SHELLMUX_LEAKY_WRITE:-0}"
  export SHELLMUX_WRITE_TIMEOUT="${SHELLMUX_WRITE_TIMEOUT:-0.05}"
  export SHELLMUX_DIR="$dir"

  # The scheduler fires deferred records into the topic fan-out via our `_fire`
  # delivery hook. SCHED_FIRE_HOOK is invoked as `<hook> <outbox_file>`; _fire
  # reads "<topic>\n<payload>" and fans it out. SCHED_OVERRIDE lets a test point
  # serve at a different scheduler (e.g. the fire-now negative control).
  local sched_script="${SCHED_OVERRIDE:-$SCHED}"
  SCHED_FIRE_HOOK="bash $SELF _fire" \
    SCHED_IDLE_POLL_MS="${SCHED_IDLE_POLL_MS:-1000}" bash "$sched_script" "$dir" &
  local sched_pid=$!

  # Slow GC reaper: one sweep every SHELLMUX_REAP_INTERVAL seconds (default 30).
  # It mostly sleeps, so idle CPU stays ~0; it only forks `find`+`rm` occasionally.
  local reap_interval="${SHELLMUX_REAP_INTERVAL:-30}"
  ( while sleep "$reap_interval"; do _reap "$dir"; done ) &
  local reap_pid=$!

  local pids=("$sched_pid" "$reap_pid")
  local exec_cmd="bash $SELF _handle $dir"

  if [ -n "$unix_path" ]; then
    rm -f "$unix_path"
    socat "UNIX-LISTEN:$unix_path,fork" "EXEC:$exec_cmd" &
    pids+=($!)
  fi
  if [ -n "$tcp_port" ]; then
    socat "TCP-LISTEN:$tcp_port,reuseaddr,fork" "EXEC:$exec_cmd" &
    pids+=($!)
  fi

  # Broker shutdown = fail-loud-for-all: reap the scheduler and every forked
  # handler so subscribers get EOF and reconnect (the reference queue's death-guard
  # that clears all senders when the central watcher dies; pkill -P from the relay).
  shutdown() { local p; for p in "${pids[@]}"; do pkill -P "$p" 2>/dev/null; kill "$p" 2>/dev/null; done; exit 0; }
  trap shutdown TERM INT
  wait
}

# ---------------------------------------------------------------------------
# client helpers — sub/pub just connect a socat to the broker and speak the
# one-line control protocol. <dir> is accepted for symmetry but unused client-side.
# ---------------------------------------------------------------------------
# usage <verb> [rc] — print the one-line invocation for a client verb and exit.
# Guards `sub`/`pub` against `--help`/`-h`/too-few-args, which otherwise tripped
# `local dir="$1" topic="$2"` under `set -u` (F4: `$2: unbound variable`).
# rc defaults to 0 (explicit `--help`/`-h` is success); a MISSING-required-arg
# call passes rc=2 and prints to stderr, so a scripter can branch on `$?` and
# distinguish "I forgot args" (2) from a happy `--help` (0) and a bad subcommand
# (1, via die) — round-002 N4. The text goes to stdout for help, stderr for error.
usage() {
  local verb="$1" rc="${2:-0}" out=1
  [ "$rc" -ne 0 ] && out=2
  case "$verb" in
    sub) printf 'usage: shellmux sub <dir> <topic> [--unix <path>|--tcp <port>]\n' >&"$out" ;;
    pub) printf 'usage: shellmux pub <dir> <topic> [--at <epoch>|--delay <s>] [--unix <path>|--tcp <port>]\n' >&"$out" ;;
  esac
  exit "$rc"
}

_endpoint() { # echoes the socat address from --unix/--tcp args
  while [ $# -gt 0 ]; do
    case "$1" in
      --unix) printf 'UNIX-CONNECT:%s' "$2"; return ;;
      --tcp)  printf 'TCP-CONNECT:127.0.0.1:%s' "$2"; return ;;
    esac
    shift
  done
  die "need --unix <path> or --tcp <port>"
}

sub() {
  case "${1:-}" in -h|--help) usage sub ;; esac        # explicit help: rc 0, stdout
  [ $# -ge 2 ] || usage sub 2                           # missing required args: rc 2, stderr
  local dir="$1" topic="$2"; shift 2
  valid_topic "$topic" || die "bad topic name (allowed: A-Za-z0-9._-, no leading dot)"
  local ep; ep="$(_endpoint "$@")" || exit 1
  # Send the SUB control line, then hold the connection open so the broker keeps
  # our mailbox alive; socat pumps the socket's incoming messages to our stdout.
  # A FIFO feeds socat's stdin: we write the control line into it and keep it open
  # (exec 4>) so socat's socket stays up with no further bytes. On SIGTERM/INT we
  # close the fd and kill socat, so the broker sees EOF and its EXIT trap unlinks
  # our mailbox FIFO (forget-on-death).
  local cf; cf="$(mktemp -u)"; mkfifo "$cf"
  socat "$ep" - <"$cf" &
  local scpid=$!
  exec 4>"$cf"
  printf 'SUB %s\n' "$topic" >&4
  trap 'exec 4>&-; kill "$scpid" 2>/dev/null; rm -f "$cf"; exit 0' TERM INT
  wait "$scpid"
  exec 4>&-; rm -f "$cf"
}

pub() {
  case "${1:-}" in -h|--help) usage pub ;; esac        # explicit help: rc 0, stdout
  [ $# -ge 2 ] || usage pub 2                           # missing required args: rc 2, stderr
  local dir="$1" topic="$2"; shift 2
  valid_topic "$topic" || die "bad topic name (allowed: A-Za-z0-9._-, no leading dot)"
  # collect --at/--delay (M3); pass remaining as the control line. Validate the
  # deadline client-side too so the publisher gets a clean nonzero rc + reason
  # (the F1/F6 contract) instead of a silent server-side handler crash.
  local opts="" ep_args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --at)    valid_deadline at    "${2:-}" || die "bad --at (non-negative epoch seconds, within SHELLMUX_MAX_DEFER_S)";    opts="$opts --at $2"; shift 2 ;;
      --delay) valid_deadline delay "${2:-}" || die "bad --delay (non-negative seconds, within SHELLMUX_MAX_DEFER_S)"; opts="$opts --delay $2"; shift 2 ;;
      --unix|--tcp) ep_args+=("$1" "$2"); shift 2 ;;
      *) shift ;;
    esac
  done
  local ep; ep="$(_endpoint "${ep_args[@]}")" || exit 1
  # Stream the control line + payload, then LINGER before closing. There is no
  # app-level publish ack in the protocol, so if we let socat close the instant
  # stdin EOFs, the broker's handler can be torn down with records still in the
  # socket buffer (measured: ~40% loss on a 4000-record burst). Holding the
  # connection open briefly lets the broker drain its receive buffer. The linger
  # is bounded (SHELLMUX_PUB_LINGER seconds, default 1) — honest limitation: a
  # burst that takes longer than the linger to drain can still lose its tail.
  local linger="${SHELLMUX_PUB_LINGER:-1}"
  { printf 'PUB %s%s\n' "$topic" "$opts"; cat; sleep "$linger"; } | socat - "$ep"
}

# ---------------------------------------------------------------------------
cmd="${1:-}"; shift || true
case "$cmd" in
  serve)   serve "$@" ;;
  sub)     sub "$@" ;;
  pub)     pub "$@" ;;
  _handle) _handle "$@" ;;
  _fire)   _fire "$@" ;;
  _reap)   _reap "$@" ;;
  version|--version|-V) printf 'shellmux %s\n' "$SHELLMUX_VERSION" ;;
  help|--help|-h) main_usage 0 ;;        # explicit help: rc 0, stdout
  '') main_usage 0 ;;                    # bare invocation: show help, rc 0
  *) printf 'shellmux: unknown command %s\n\n' "$cmd" >&2; main_usage 1 ;;  # bad cmd: rc 1, stderr
esac
